{
  "name": "scriptureflow",
  "private": true,
  "version": "1.0.10",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron",
    "lint": "tsc --noEmit",
    "setup-bibles": "node scripts/download-bibles.js",
    "setup-bibles:kjv": "node scripts/download-bibles.js kjv",
    "setup-bibles:force": "node scripts/download-bibles.js --force",
    "electron:compile": "node -e \"const fs=require('fs');fs.mkdirSync('dist-electron',{recursive:true});fs.writeFileSync('dist-electron/package.json','{\\\"type\\\":\\\"commonjs\\\"}');\" && tsc --project tsconfig.electron.json",
    "electron:dev": "start \"Vite\" cmd /k npm run dev && timeout /t 4 && npm run electron:compile && set NODE_ENV=development&& npx electron .",
    "electron:start": "npm run electron:compile && cross-env NODE_ENV=development npx electron .",
    "electron:build": "npm run build && npm run electron:compile",
    "setup-ndi": "npx @electron/rebuild -f -w grandiose",
    "electron:pack": "npm run electron:build && electron-builder --publish never",
    "electron:publish": "npm run electron:build && electron-builder --publish always"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.2.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "grandiose": "^0.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
